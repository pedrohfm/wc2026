# Copy this file to `.env` and fill in your own keys, then either
#   source .env          (daily.sh does this automatically if .env exists)
# or add the export lines to your shell profile (~/.zshrc, ~/.bashrc).
#
# NEVER commit your real .env — it is git-ignored on purpose. This .env.example
# (no real values) is the only key-related file that belongs in the repo.

# Match results — football-data.org (free tier covers the World Cup).
# Get a free token: https://www.football-data.org/client/register
export FOOTBALL_DATA_TOKEN=

# Bookmaker odds — The Odds API (free tier).
# Get a free key: https://the-odds-api.com/
export ODDS_API_KEY=

# Optional: override the football-data season (defaults to the current one).
# export FOOTBALL_DATA_SEASON=2026
